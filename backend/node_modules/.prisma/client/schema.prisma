// =============================================================================
// TrackNFix 3.0 — Prisma Database Schema
// System: Vehicle Service Record Management — Jayakody Auto Electrical
// Database: PostgreSQL
//
// ── Tables (Models) ──────────────────────────────────────────────────────────
//  1.  User               — Employees, Admins, and Managers (all roles in one table)
//  2.  Vehicle            — Registered vehicles with owner contact details
//  3.  Job                — Service/repair jobs created by employees
//  4.  JobImage           — Before / After / Part photos attached to a job
//  5.  Quotation          — Cost quotations created by admin, reviewed by manager
//  6.  QuotationItem      — Individual line items (parts + labour) in a quotation
//  7.  SparePart          — Inventory of spare parts managed by the manager
//  8.  StockLedger        — Audit log of every stock quantity change per spare part
//  9.  Notification       — In-app notifications sent between roles
//  10. Attendance         — Daily attendance record for each employee
//  11. AttendanceRequest  — Pending check-in / check-out / overtime requests awaiting admin approval
//  12. Leave              — Leave applications submitted by employees
//  13. Overtime           — Overtime session requests submitted by employees
//  14. Holiday            — Single-day holiday requests submitted by employees
//  15. AttendanceHistory  — Archived snapshot of attendance data after admin archives a period
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  name               String
  email              String              @unique
  password           String
  role               Role
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  address            String?
  isActive           Boolean             @default(true)
  isFirstLogin       Boolean             @default(true)
  nicNumber          String?             @unique
  otpCode            String?
  otpExpiry          DateTime?
  attendanceRecords  Attendance[]        @relation("EmployeeAttendance")
  attendanceHistory  AttendanceHistory[] @relation("EmployeeHistory")
  adminReviews       AttendanceRequest[] @relation("AdminReviews")
  attendanceRequests AttendanceRequest[] @relation("EmployeeRequests")
  adminHolidays      Holiday[]           @relation("AdminHolidays")
  holidays           Holiday[]           @relation("EmployeeHolidays")
  jobs               Job[]
  adminLeaves        Leave[]             @relation("AdminLeaves")
  leaves             Leave[]             @relation("EmployeeLeaves")
  notifications      Notification[]
  adminOvertime      Overtime[]          @relation("AdminOvertime")
  overtimes          Overtime[]          @relation("EmployeeOvertime")
  adminQuotations    Quotation[]         @relation("AdminQuotations")
  managerQuotations  Quotation[]         @relation("ManagerQuotations")
}

model Vehicle {
  id             String       @id @default(uuid())
  vehicleNumber  String       @unique
  ownerName      String?
  address        String?
  telephone      String?
  vehicleType    VehicleType?
  color          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  whatsappNumber String?
  jobs           Job[]
  quotations     Quotation[]
}

model Job {
  id               String      @id @default(uuid())
  jobNumber        Int         @unique @default(autoincrement())
  vehicleId        String
  employeeId       String
  jobType          JobType
  status           JobStatus   @default(DRAFT)
  notes            String?
  insuranceCompany String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  voiceNoteUrl     String?
  employee         User        @relation(fields: [employeeId], references: [id])
  vehicle          Vehicle     @relation(fields: [vehicleId], references: [id])
  images           JobImage[]
  quotations       Quotation[]
}

model JobImage {
  id        String     @id @default(uuid())
  jobId     String
  phase     ImagePhase
  url       String
  caption   String?
  createdAt DateTime   @default(now())
  job       Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Quotation {
  id               String          @id @default(uuid())
  jobId            String
  vehicleId        String
  adminId          String
  managerId        String?
  vehicleNumber    String
  ownerName        String?
  address          String?
  telephone        String?
  vehicleType      VehicleType?
  color            String?
  insuranceCompany String?
  jobDetails       String?
  totalAmount      Float?
  pdfUrl           String?
  status           QuotationStatus @default(DRAFT)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  notificationSent Boolean         @default(false)
  notifiedAt       DateTime?
  whatsappNumber   String?
  admin            User            @relation("AdminQuotations", fields: [adminId], references: [id])
  job              Job             @relation(fields: [jobId], references: [id])
  manager          User?           @relation("ManagerQuotations", fields: [managerId], references: [id])
  vehicle          Vehicle         @relation(fields: [vehicleId], references: [id])
  items            QuotationItem[]
}

model QuotationItem {
  id           String     @id @default(uuid())
  quotationId  String
  description  String
  partReplaced String?
  price        Float      @default(0)
  laborCost    Float      @default(0)
  quantity     Int        @default(1)
  sparePartId  String?
  quotation    Quotation  @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  sparePart    SparePart? @relation(fields: [sparePartId], references: [id])
}

model SparePart {
  id                String          @id @default(uuid())
  name              String
  serialNumber      String          @unique
  description       String?
  boughtPrice       Float
  sellingPrice      Float
  quantity          Int             @default(0)
  lowStockThreshold Int             @default(5)
  supplierName      String?
  supplierDetails   String?
  purchaseDate      DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  quotationItems    QuotationItem[]
  stockLedger       StockLedger[]
}

model StockLedger {
  id          String    @id @default(uuid())
  sparePartId String
  change      Int
  reason      String?
  quotationId String?
  jobNumber   Int?
  createdAt   DateTime  @default(now())
  sparePart   SparePart @relation(fields: [sparePartId], references: [id])
}

model Notification {
  id            String   @id @default(uuid())
  fromRole      Role
  toRole        Role
  message       String
  vehicleNumber String?
  quotationId   String?
  userId        String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])
}

model Attendance {
  id            String           @id @default(uuid())
  employeeId    String
  date          DateTime         @db.Date
  checkInTime   DateTime?
  checkOutTime  DateTime?
  status        AttendanceStatus @default(PRESENT)
  overtimeStart DateTime?
  overtimeEnd   DateTime?
  notes         String?
  createdAt     DateTime         @default(now())
  employee      User             @relation("EmployeeAttendance", fields: [employeeId], references: [id])

  @@unique([employeeId, date])
}

model AttendanceRequest {
  id            String                @id @default(uuid())
  employeeId    String
  type          AttendanceRequestType
  requestedTime DateTime
  reason        String?
  status        RequestStatus         @default(PENDING)
  adminId       String?
  reviewedAt    DateTime?
  createdAt     DateTime              @default(now())
  admin         User?                 @relation("AdminReviews", fields: [adminId], references: [id])
  employee      User                  @relation("EmployeeRequests", fields: [employeeId], references: [id])
}

model Leave {
  id                String      @id @default(uuid())
  employeeId        String
  leaveFrom         DateTime
  leaveTo           DateTime
  reason            String?
  status            LeaveStatus @default(PENDING)
  leaveEndConfirmed Boolean     @default(false)
  adminId           String?
  createdAt         DateTime    @default(now())
  admin             User?       @relation("AdminLeaves", fields: [adminId], references: [id])
  employee          User        @relation("EmployeeLeaves", fields: [employeeId], references: [id])
}

model Overtime {
  id            String         @id @default(uuid())
  employeeId    String
  overtimeStart DateTime
  overtimeEnd   DateTime?
  status        OvertimeStatus @default(PENDING)
  endConfirmed  Boolean        @default(false)
  adminId       String?
  reason        String?
  createdAt     DateTime       @default(now())
  admin         User?          @relation("AdminOvertime", fields: [adminId], references: [id])
  employee      User           @relation("EmployeeOvertime", fields: [employeeId], references: [id])
}

model Holiday {
  id          String        @id @default(uuid())
  employeeId  String
  declaredBy  String?
  holidayDate DateTime      @db.Date
  description String?
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  admin       User?         @relation("AdminHolidays", fields: [declaredBy], references: [id])
  employee    User          @relation("EmployeeHolidays", fields: [employeeId], references: [id])
}

model AttendanceHistory {
  id               String    @id @default(uuid())
  employeeId       String
  employeeName     String
  date             DateTime
  checkInTime      DateTime?
  checkOutTime     DateTime?
  attendanceStatus String?
  leaveFrom        DateTime?
  leaveTo          DateTime?
  leaveReason      String?
  leaveStatus      String?
  overtimeStart    DateTime?
  overtimeEnd      DateTime?
  overtimeStatus   String?
  notes            String?
  archivedAt       DateTime  @default(now())
  employee         User      @relation("EmployeeHistory", fields: [employeeId], references: [id])
}

enum Role {
  EMPLOYEE
  ADMIN
  MANAGER
}

enum JobType {
  SERVICE
  REPAIR
  ACCIDENT_RECOVERY
}

enum JobStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  QUOTED
  FINALIZED
  COMPLETED
}

enum ImagePhase {
  BEFORE
  AFTER
  PART
}

enum QuotationStatus {
  DRAFT
  SENT_TO_MANAGER
  FINALIZED
  CUSTOMER_NOTIFIED
}

enum AttendanceStatus {
  PRESENT
  EARLY_CHECKOUT
  OVERTIME
  HOLIDAY
  ON_LEAVE
  ABSENT
}

enum AttendanceRequestType {
  CHECKIN
  CHECKOUT
  EARLY_CHECKOUT
  OVERTIME_START
  OVERTIME_END
  LEAVE_START
  LEAVE_END
  HOLIDAY
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OvertimeStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

enum VehicleType {
  CAR
  VAN
  BUS
  MOTORCYCLE
  THREE_WHEELER
  LORRY
  PICKUP
}
