// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  ADMIN
  MANAGER
}

enum JobType {
  SERVICE
  REPAIR
  ACCIDENT_RECOVERY
}

enum JobStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  QUOTED
  FINALIZED
}

enum ImagePhase {
  BEFORE
  AFTER
  PART
}

enum QuotationStatus {
  DRAFT
  SENT_TO_MANAGER
  FINALIZED
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  password     String
  role         Role
  nicNumber    String?   @unique
  address      String?
  isFirstLogin Boolean   @default(true)
  isActive     Boolean   @default(true)
  otpCode      String?
  otpExpiry    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  jobs              Job[]
  adminQuotations   Quotation[]         @relation("AdminQuotations")
  managerQuotations Quotation[]         @relation("ManagerQuotations")
  notifications     Notification[]

  // Attendance relations
  attendanceRecords  Attendance[]        @relation("EmployeeAttendance")
  attendanceRequests AttendanceRequest[] @relation("EmployeeRequests")
  adminReviews       AttendanceRequest[] @relation("AdminReviews")
  leaves             Leave[]             @relation("EmployeeLeaves")
  adminLeaves        Leave[]             @relation("AdminLeaves")
  overtimes          Overtime[]          @relation("EmployeeOvertime")
  adminOvertime      Overtime[]          @relation("AdminOvertime")
  holidays           Holiday[]           @relation("EmployeeHolidays")
  adminHolidays      Holiday[]           @relation("AdminHolidays")
  attendanceHistory  AttendanceHistory[] @relation("EmployeeHistory")
}

model Vehicle {
  id            String   @id @default(uuid())
  vehicleNumber String   @unique
  ownerName     String?
  address       String?
  telephone     String?
  vehicleType   String?
  color         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  jobs       Job[]
  quotations Quotation[]
}

model Job {
  id               String    @id @default(uuid())
  jobNumber        Int       @unique @default(autoincrement())
  vehicleId        String
  employeeId       String
  jobType          JobType
  status           JobStatus @default(DRAFT)
  notes            String?
  voiceNoteUrl     String?
  insuranceCompany String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  vehicle    Vehicle    @relation(fields: [vehicleId], references: [id])
  employee   User       @relation(fields: [employeeId], references: [id])
  images     JobImage[]
  quotations Quotation[]
}

model JobImage {
  id        String     @id @default(uuid())
  jobId     String
  phase     ImagePhase
  url       String
  caption   String?
  createdAt DateTime   @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Quotation {
  id               String          @id @default(uuid())
  jobId            String
  vehicleId        String
  adminId          String
  managerId        String?
  vehicleNumber    String
  ownerName        String?
  address          String?
  telephone        String?
  vehicleType      String?
  color            String?
  insuranceCompany String?
  jobDetails       String?
  totalAmount      Float?
  pdfUrl           String?
  status           QuotationStatus @default(DRAFT)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  job     Job              @relation(fields: [jobId], references: [id])
  vehicle Vehicle          @relation(fields: [vehicleId], references: [id])
  admin   User             @relation("AdminQuotations", fields: [adminId], references: [id])
  manager User?            @relation("ManagerQuotations", fields: [managerId], references: [id])
  items   QuotationItem[]
}

model QuotationItem {
  id           String  @id @default(uuid())
  quotationId  String
  description  String
  partReplaced String?
  price        Float   @default(0)
  laborCost    Float   @default(0)

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model Notification {
  id            String   @id @default(uuid())
  fromRole      Role
  toRole        Role
  message       String
  vehicleNumber String?
  quotationId   String?
  userId        String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

// ─── Attendance Module ───────────────────────────────────────────────────────

enum AttendanceStatus {
  PRESENT
  EARLY_CHECKOUT
  OVERTIME
  HOLIDAY
  ON_LEAVE
  ABSENT
}

enum AttendanceRequestType {
  CHECKIN
  CHECKOUT
  EARLY_CHECKOUT
  OVERTIME_START
  OVERTIME_END
  LEAVE_START
  LEAVE_END
  HOLIDAY
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OvertimeStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

model Attendance {
  id           String           @id @default(uuid())
  employeeId   String
  date         DateTime         @db.Date
  checkInTime  DateTime?
  checkOutTime DateTime?
  status       AttendanceStatus @default(PRESENT)
  overtimeStart DateTime?
  overtimeEnd  DateTime?
  notes        String?
  createdAt    DateTime         @default(now())

  employee User @relation("EmployeeAttendance", fields: [employeeId], references: [id])

  @@unique([employeeId, date])
}

model AttendanceRequest {
  id            String                @id @default(uuid())
  employeeId    String
  type          AttendanceRequestType
  requestedTime DateTime
  reason        String?
  status        RequestStatus         @default(PENDING)
  adminId       String?
  reviewedAt    DateTime?
  createdAt     DateTime              @default(now())

  employee User  @relation("EmployeeRequests", fields: [employeeId], references: [id])
  admin    User? @relation("AdminReviews", fields: [adminId], references: [id])
}

model Leave {
  id                String      @id @default(uuid())
  employeeId        String
  leaveFrom         DateTime
  leaveTo           DateTime
  reason            String?
  status            LeaveStatus @default(PENDING)
  leaveEndConfirmed Boolean     @default(false)
  adminId           String?
  createdAt         DateTime    @default(now())

  employee User  @relation("EmployeeLeaves", fields: [employeeId], references: [id])
  admin    User? @relation("AdminLeaves", fields: [adminId], references: [id])
}

model Overtime {
  id            String         @id @default(uuid())
  employeeId    String
  overtimeStart DateTime
  overtimeEnd   DateTime?
  status        OvertimeStatus @default(PENDING)
  endConfirmed  Boolean        @default(false)
  adminId       String?
  reason        String?
  createdAt     DateTime       @default(now())

  employee User  @relation("EmployeeOvertime", fields: [employeeId], references: [id])
  admin    User? @relation("AdminOvertime", fields: [adminId], references: [id])
}

model Holiday {
  id          String        @id @default(uuid())
  employeeId  String
  declaredBy  String?
  holidayDate DateTime      @db.Date
  description String?
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())

  employee User  @relation("EmployeeHolidays", fields: [employeeId], references: [id])
  admin    User? @relation("AdminHolidays", fields: [declaredBy], references: [id])
}

model AttendanceHistory {
  id               String    @id @default(uuid())
  employeeId       String
  employeeName     String
  date             DateTime
  checkInTime      DateTime?
  checkOutTime     DateTime?
  attendanceStatus String?
  leaveFrom        DateTime?
  leaveTo          DateTime?
  leaveReason      String?
  leaveStatus      String?
  overtimeStart    DateTime?
  overtimeEnd      DateTime?
  overtimeStatus   String?
  notes            String?
  archivedAt       DateTime  @default(now())

  employee User @relation("EmployeeHistory", fields: [employeeId], references: [id])
}
